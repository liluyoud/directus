@inherits LayoutComponentBase
@inject DirectusAuthStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="app-shell">
    <AuthorizeView>
        <Authorized>
            <nav class="top-nav">
                <div class="nav-brand">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="brand-icon">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                    <span class="brand-text">Qute</span>
                </div>

                <div class="nav-actions">
                    <div class="user-info">
                        <div class="user-avatar">
                            @(context.User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")
                        </div>
                        <span class="user-name">@context.User.Identity?.Name</span>
                    </div>
                    <button class="btn-logout" @onclick="HandleLogoutAsync" title="Sair">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        <span>Sair</span>
                    </button>
                </div>
            </nav>
        </Authorized>
    </AuthorizeView>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private async Task HandleLogoutAsync()
    {
        await AuthProvider.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
