@page "/login"
@inject DirectusAuthStateProvider AuthProvider
@inject NavigationManager Navigation

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5"/>
                    <path d="M2 12l10 5 10-5"/>
                </svg>
            </div>
            <h1>Qute</h1>
            <p class="login-subtitle">Entre com suas credenciais para continuar</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="login-error">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="error-icon">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                <span>@_errorMessage</span>
            </div>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync" FormName="login">
            <div class="form-group">
                <label for="email">E-mail</label>
                <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <InputText id="email" @bind-Value="_model.Email" placeholder="seu@email.com"
                               class="form-input" disabled="@_isLoading" />
                </div>
            </div>

            <div class="form-group">
                <label for="password">Senha</label>
                <div class="input-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <InputText id="password" @bind-Value="_model.Password" type="password"
                               placeholder="••••••••" class="form-input" disabled="@_isLoading" />
                </div>
            </div>

            <button type="submit" class="btn-login" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="btn-spinner"></span>
                    <span>Entrando...</span>
                }
                else
                {
                    <span>Entrar</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _errorMessage;
    private bool _isLoading;

    private sealed class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }

    private async Task HandleLoginAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            await AuthProvider.LoginAsync(_model.Email, _model.Password);
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message.Contains("401") || ex.Message.Contains("Unauthorized")
                ? "E-mail ou senha inválidos."
                : $"Erro ao fazer login: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
