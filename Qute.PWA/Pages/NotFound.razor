@page "/not-found"
@layout MainLayout

<PageTitle>Qute — Página não encontrada</PageTitle>

<div class="login-wrapper">
    <div class="login-card" style="text-align: center;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🔍</div>
        <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Página não encontrada</h1>
        <p style="color: var(--text-muted); margin-bottom: 1.5rem;">O conteúdo que você procura não existe.</p>
        <a href="/" class="btn-login" style="display: inline-flex; text-decoration: none; max-width: 200px; margin: 0 auto;">
            Voltar ao início
        </a>
    </div>
</div>